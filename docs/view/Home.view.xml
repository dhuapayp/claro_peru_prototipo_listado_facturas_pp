<mvc:View controllerName="claro.com.listadofacturas.controller.Home"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:core="sap.ui.core"
    xmlns="sap.m">
    <Page id="page" title="{i18n>homeTitle}">
        <content>
            <VBox
                alignItems="Center"
                justifyContent="Center"
                class="sapUiLargeMarginTop">
                <VBox
                    alignItems="Center"
                    class="sapUiMediumMargin">
                    <core:Icon
                        src="sap-icon://document"
                        size="5rem"
                        color="#0070F2"/>
                    <Title
                        text="{i18n>appTitle}"
                        level="H1"
                        class="sapUiSmallMarginTop"/>
                    <Text
                        text="{i18n>appDescription}"
                        class="sapUiSmallMarginTop"/>
                    <Button
                        text="{i18n>goToInvoices}"
                        type="Emphasized"
                        press=".onGoToInvoices"
                        class="sapUiMediumMarginTop"/>
                </VBox>
            </VBox>
        </content>
    </Page>
</mvc:View>